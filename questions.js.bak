                q: '"I ___ never visited France before." — Choose the correct auxiliary.',
                options: ['was', 'did', 'have', 'had'],
                answer: 2,
                hint: 'Present perfect: have/has + past participle. "I have never visited" is correct.',
            },
            {
                id: '5-1-3',
                theme: 'Perfect Tenses',
                q: '"By the time I arrived, the film ___." — Choose the correct form.',
                options: [
                    'has started',
                    'have started',
                    'was started',
                    'had started',
                ],
                answer: 3,
                hint: 'Past perfect (had + past participle) shows an action completed BEFORE another past action.',
            },
            {
                id: '5-1-4',
                theme: 'Perfect Tenses',
                q: '"She ___ already eaten when we called." — Choose the correct auxiliary.',
                options: ['has', 'have', 'had', 'was'],
                answer: 2,
                hint: 'Past perfect uses "had" for all subjects: she had already eaten = before the call.',
            },
            {
                id: '5-1-5',
                theme: 'Perfect Tenses',
                q: '"They ___ been friends since childhood." — Choose the correct auxiliary.',
                options: ['was', 'had', 'have', 'are'],
                answer: 2,
                hint: 'Present perfect with "since" = have/has + been: They have been friends since childhood.',
            },
        ],

        /* ── Sub-level 2 · Theme: Passive Voice ─────────────── */
        2: [
            {
                id: '5-2-1',
                theme: 'Passive Voice',
                q: '"The project was ___ by the team." — Choose the correct form.',
                options: ['complete', 'completes', 'completing', 'completed'],
                answer: 3,
                hint: 'Passive voice = was/were + past participle. "Completed" is the past participle.',
            },
            {
                id: '5-2-2',
                theme: 'Passive Voice',
                q: 'Which sentence is in the PASSIVE voice?',
                options: [
                    'The dog chased the cat.',
                    'She wrote the letter.',
                    'The window was broken by the ball.',
                    'He is eating lunch.',
                ],
                answer: 2,
                hint: 'Passive voice: the subject receives the action. "The window was broken" — the window did not act.',
            },
            {
                id: '5-2-3',
                theme: 'Passive Voice',
                q: '"The book ___ written in 1984." — Choose the correct auxiliary.',
                options: ['is', 'has', 'was', 'were'],
                answer: 2,
                hint: 'Past passive uses "was" (singular). "The book was written" is correct.',
            },
            {
                id: '5-2-4',
                theme: 'Passive Voice',
                q: 'Change to PASSIVE: "The teacher explains the lesson."',
                options: [
                    'The lesson explains the teacher.',
                    'The lesson is explaining the teacher.',
                    'The lesson is explained by the teacher.',
                    'The lesson has explained by the teacher.',
                ],
                answer: 2,
                hint: 'Present passive: is/are + past participle. "The lesson is explained by the teacher."',
            },
            {
                id: '5-2-5',
                theme: 'Passive Voice',
                q: '"English ___ spoken all over the world." — Choose the correct verb form.',
                options: ['speaks', 'spoke', 'is spoke', 'is spoken'],
                answer: 3,
                hint: 'Present passive: is + past participle. "Is spoken" is the correct form.',
            },
        ],

        /* ── Sub-level 3 · Theme: Figurative Language ────────── */
        3: [
            {
                id: '5-3-1',
                theme: 'Figurative Language',
                q: 'Which sentence uses a SIMILE?',
                options: [
                    '"He ran fast."',
                    '"He ran like the wind."',
                    '"He was the wind."',
                    '"It was very windy."',
                ],
                answer: 1,
                hint: 'A simile compares two things using "like" or "as". "Like the wind" is a simile.',
            },
            {
                id: '5-3-2',
                theme: 'Figurative Language',
                q: '"The thunder roared angrily." — This is an example of ___.',
                options: ['a simile', 'a metaphor', 'personification', 'alliteration'],
                answer: 2,
                hint: 'Personification gives human qualities to non-human things. Thunder cannot really be angry.',
            },
            {
                id: '5-3-3',
                theme: 'Figurative Language',
                q: '"Her eyes were stars." — This is an example of ___.',
                options: ['a simile', 'a metaphor', 'personification', 'hyperbole'],
                answer: 1,
                hint: 'A metaphor says one thing IS another directly, without "like" or "as".',
            },
            {
                id: '5-3-4',
                theme: 'Figurative Language',
                q: '"He ate a mountain of food." — What figure of speech is this?',
                options: ['personification', 'alliteration', 'a simile', 'hyperbole'],
                answer: 3,
                hint: 'Hyperbole is an extreme exaggeration for effect. He did not literally eat a mountain.',
            },
            {
                id: '5-3-5',
                theme: 'Figurative Language',
                q: '"The bees buzzed busily." — What sound device is used?',
                options: ['rhyme', 'assonance', 'alliteration', 'personification'],
                answer: 2,
                hint: 'Alliteration is the repetition of the same consonant sound at the start of nearby words: b-b-b.',
            },
        ],

        /* ── Sub-level 4 · Theme: Advanced Punctuation ────────── */
        4: [
            {
                id: '5-4-1',
                theme: 'Advanced Punctuation',
                q: 'Which sentence is correctly punctuated?',
                options: [
                    "its a nice day",
                    "Its a nice day",
                    "It's a nice day",
                    "its' a nice day",
                ],
                answer: 2,
                hint: '"It\'s" is a contraction of "it is". The apostrophe replaces the missing "i".',
            },
            {
                id: '5-4-2',
                theme: 'Advanced Punctuation',
                q: 'Which sentence uses a COMMA correctly?',
                options: [
                    'After dinner we went for, a walk.',
                    'After dinner, we went for a walk.',
                    'After, dinner we went for a walk.',
                    'After dinner we, went for a walk.',
                ],
                answer: 1,
                hint: 'A comma is used after an introductory phrase: "After dinner," sets the scene before the main clause.',
            },
            {
                id: '5-4-3',
                theme: 'Advanced Punctuation',
                q: 'Which sentence uses a COLON correctly?',
                options: [
                    'She brought: everything a tent and food.',
                    'She: brought everything a tent and food.',
                    'She brought everything: a tent, a sleeping bag, and food.',
                    'She brought everything a tent, a sleeping bag: and food.',
                ],
                answer: 2,
                hint: 'A colon introduces a list or explanation after a complete clause.',
            },
            {
                id: '5-4-4',
                theme: 'Advanced Punctuation',
                q: '"The boys books were left on the desk." — Where should the apostrophe go?',
                options: [
                    "The boy's books",
                    "The boys' books",
                    "The boys books'",
                    "The boy's book's",
                ],
                answer: 1,
                hint: '"Boys" is plural (more than one boy) → possessive plural adds apostrophe AFTER the s: boys\'.',
            },
            {
                id: '5-4-5',
                theme: 'Advanced Punctuation',
                q: 'Which sentence uses a SEMICOLON correctly?',
                options: [
                    'I love reading; it relaxes my mind.',
                    'I love; reading it relaxes my mind.',
                    'I love reading it; relaxes my mind.',
                    'I; love reading it relaxes my mind.',
                ],
                answer: 0,
                hint: 'A semicolon joins two related independent clauses. Both sides must be complete sentences.',
            },
        ],

        /* ── Sub-level 5 · Theme: Complex Sentences & Connectives */
        5: [
            {
                id: '5-5-1',
                theme: 'Complex Sentences & Connectives',
                q: '"Despite the rain, ___ went for a walk." — What fits best?',
                options: ['but they', 'however they', 'they still', 'yet they'],
                answer: 2,
                hint: '"They still" is the most natural continuation after "Despite the rain,".',
            },
            {
                id: '5-5-2',
                theme: 'Complex Sentences & Connectives',
                q: 'Which connecting word shows CONTRAST?',
                options: ['therefore', 'moreover', 'however', 'furthermore'],
                answer: 2,
                hint: '"However" introduces a contrasting or opposing idea. "Therefore" shows a result.',
            },
            {
                id: '5-5-3',
                theme: 'Complex Sentences & Connectives',
                q: '"She passed the exam ___ she studied very hard." — Which word shows the CAUSE?',
                options: ['so', 'but', 'because', 'although'],
                answer: 2,
                hint: '"Because" introduces the reason/cause: she passed → because she studied hard.',
            },
            {
                id: '5-5-4',
                theme: 'Complex Sentences & Connectives',
                q: 'Which sentence contains a RELATIVE CLAUSE?',
                options: [
                    'She is very talented.',
                    'He runs every morning.',
                    'The man who fixed my car is very skilled.',
                    'They arrived late yesterday.',
                ],
                answer: 2,
                hint: 'A relative clause begins with who, which, or that and gives extra info: "who fixed my car".',
            },
            {
                id: '5-5-5',
                theme: 'Complex Sentences & Connectives',
                q: '"He is brilliant; ___, he lacks confidence." — Which connective fits best?',
                options: ['moreover', 'in addition', 'however', 'similarly'],
                answer: 2,
                hint: '"However" shows the contrast: brilliant (positive) vs. lacks confidence (negative).',
            },
        ],
    },
