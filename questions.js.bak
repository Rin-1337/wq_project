                hint: 'With he/she/it in negatives, use "doesn\'t" (does + not).',
            },
            {
                id: '3-1-4',
                theme: 'Subject-Verb Agreement',
                q: 'Which sentence is CORRECT?',
                options: [
                    'The boys plays football.',
                    'The boys play football.',
                    'The boys playing football.',
                    'The boys played football.',
                ],
                answer: 1,
                hint: '"Boys" is plural, so the verb has no -s. "The boys play" is correct in present simple.',
            },
            {
                id: '3-1-5',
                theme: 'Subject-Verb Agreement',
                q: '"My sister ___ to music every evening." — Choose the correct verb.',
                options: ['listen', 'listening', 'listens', 'listened'],
                answer: 2,
                hint: '"Sister" = she → third-person singular → add -s: "listens".',
            },
        ],

        /* ── Sub-level 2 · Theme: Verb Tenses ──────────────── */
        2: [
