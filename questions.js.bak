                id: '3-2-1',
                theme: 'Verb Tenses',
                q: 'What is the past tense of "eat"?',
                options: ['eated', 'eaten', 'ate', 'eats'],
                answer: 2,
                hint: '"Ate" is the simple past of "eat". It is an irregular verb.',
            },
            {
                id: '3-2-2',
                theme: 'Verb Tenses',
                q: '"She ___ go to the party tomorrow." — Choose the correct future form.',
                options: ['was', 'is', 'will', 'did'],
                answer: 2,
                hint: 'Future simple uses "will + base verb". "She will go" is correct.',
            },
            {
                id: '3-2-3',
                theme: 'Verb Tenses',
                q: 'What is the correct present continuous form of "run"?',
                options: ['runing', 'running', 'runnig', 'runs'],
