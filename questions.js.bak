            },
            {
                id: '4-1-3',
                theme: 'Simple Inference',
                q: '"It was raining, so Mary took her umbrella." — Why did Mary take her umbrella?',
                options: [
                    'It was sunny.',
                    'It was raining.',
                    'She was going swimming.',
                    'She lost her bag.',
                ],
                answer: 1,
                hint: 'The word "so" signals the result: raining → she took her umbrella.',
            },
            {
                id: '4-1-4',
