                answer: 2,
                hint: '6 pm minus 9 am = 9 hours.',
            },
            {
                id: '4-1-5',
                theme: 'Simple Inference',
                q: '"Ben loves football. He trains every Monday and Wednesday." — How many times a week does Ben train?',
                options: ['1', '2', '3', '4'],
                answer: 1,
                hint: 'Monday + Wednesday = 2 days per week.',
            },
        ],

        /* ── Sub-level 2 · Theme: Cause & Effect ────────────── */
        2: [
