/**
 * questions.js — Question Bank for WordQuest
 * ============================================
 * Nested structure: QUESTIONS[stageId][subLevelId] = Array of 5 questions
 *
 * Game Modes (ประเภทของ Gameplay แต่ละ Stage):
 *   Stage 1 — multiple-choice  : 4-choice MCQ มาตรฐาน (Vocabulary basics)
 *   Stage 2 — type-in-blank    : พิมพ์คำตอบในช่องว่าง (Spelling & Grammar)
 *   Stage 3 — sentence-scramble: เรียงคำที่สลับกันให้เป็นประโยคที่ถูกต้อง
 *   Stage 4 — true-false       : ตัดสิน True/False อย่างรวดเร็ว (Time Blitz)
 *   Stage 5 — image-word-match : โจทย์คำอธิบาย/hint → เลือกคำที่ตรงกัน (Advanced)
 *
 * Stages:
 *   1 — The Basics       (Alphabet → Pronouns → Verbs → Sentences → Numbers)
 *   2 — Word Builder     (Fill-in-the-Blank: Spelling & Grammar focus)
 *   3 — Grammar Gates    (Sentence Scramble: เรียงประโยค)
 *   4 — Read & Conquer   (True/False Blitz: ตัดสิน statement ถูก/ผิด)
 *   5 — Master's Hall    (Image-to-Word Match: Advanced comprehension)
 *
 * Schema ตาม mode:
 *
 *   multiple-choice:
 *     id, theme, q, options[], answer (index 0-3), hint
 *
 *   type-in-blank:
 *     id, theme, q (ประโยคมี ___), answer (string), acceptedAnswers[] (อนุญาต variant),
 *     hint, timeLimit (วินาที)
 *
 *   sentence-scramble:
 *     id, theme, words[] (array คำที่สลับแล้ว), correctOrder[] (index ลำดับที่ถูก),
 *     hint, timeLimit
 *
 *   true-false:
 *     id, theme, statement, answer (boolean), hint, timeLimit
 *
 *   image-word-match:
 *     id, theme, imageEmoji (emoji แทน image), description (คำอธิบายตัวชี้),
 *     options[], answer (index 0-3), hint
 */

window.QUESTIONS = {

