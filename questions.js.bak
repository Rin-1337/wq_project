                options: [
                    'She go to school.',
                    'She goes to school.',
                    'She going to school.',
                    'She goed to school.',
                ],
                answer: 1,
                hint: 'Third-person singular (she/he/it) uses "goes" in the present simple.',
            },
            {
                id: '3-1-2',
                theme: 'Subject-Verb Agreement',
                q: '"They ___ eating lunch right now." — Choose the correct verb.',
                options: ['is', 'am', 'are', 'was'],
