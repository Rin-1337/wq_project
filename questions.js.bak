                q: 'In a sequence — "First", ___, "Finally" — which word fits the middle?',
                options: ['however', 'although', 'next', 'since'],
                answer: 2,
                hint: 'The order is: First, Next, Finally. "Next" connects middle steps.',
            },
        ],

        /* ── Sub-level 4 · Theme: Main Idea ─────────────────── */
